<?xml version="1.0" encoding="UTF-8"?>

<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
  version="3.0">

  <persistence-unit name="BibliPU">

    <class>fr.turgot.dao.model.User</class>
    <class>fr.turgot.dao.model.Etudiant</class>
    <class>fr.turgot.dao.model.Professeur</class>
    <class>fr.turgot.dao.model.Ressource</class>
    <class>fr.turgot.dao.model.Livre</class>
    <class>fr.turgot.dao.model.Document</class>
    <class>fr.turgot.dao.model.Emprunt</class>
    <class>fr.turgot.dao.model.Bibliothecaire</class>
    <class>fr.turgot.dao.model.Admin</class>

    <properties>
      <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver" />
      <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/biblidb" />
      <property name="jakarta.persistence.jdbc.user" value="root" />
      <property name="jakarta.persistence.jdbc.password" value="root" />
      <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect" />
      <property name="hibernate.hbm2ddl.auto" value="update" />
      <property name="hibernate.show_sql" value="true" />
    </properties>

  </persistence-unit>

</persistence>